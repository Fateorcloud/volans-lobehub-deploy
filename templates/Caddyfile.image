{
	email {$CADDY_ACME_EMAIL}
}

{$IMAGE_DOMAIN} {
	encode zstd gzip

	log {
		output file /var/log/caddy/image-access.log {
			roll_size 10mb
			roll_keep 10
			roll_keep_for 168h
		}
	}

	@protected {
		not path /api-proxy/*
	}

	basic_auth @protected {
		{$IMAGE_BASIC_AUTH_USER} {$IMAGE_BASIC_AUTH_HASH}
	}

	reverse_proxy gpt-image-playground:80 {
		transport http {
			read_timeout 600s
			write_timeout 600s
		}
	}
}
