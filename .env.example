# Core project settings
DEPLOY_DIR=/opt/lobehub
TZ=Asia/Shanghai
# SSH port the firewall keeps open. `deploy.sh fresh` auto-detects the port sshd
# is actually listening on; if you use a non-standard SSH port, set it here too
# so UFW can never lock you out. Most servers use 22.
SSH_PORT=22

# Local-only access. Keep these on 127.0.0.1 for the first test phase.
LOBE_PORT=3210
RUSTFS_PORT=9000
RUSTFS_ADMIN_PORT=9001
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379
SEARXNG_HOST_PORT=18080

# Public access via Cloudflare Tunnel (optional). Leave COMPOSE_PROFILES empty
# for local-only. To go public: create a tunnel in the Cloudflare Zero Trust
# dashboard, route chat.<domain> -> 127.0.0.1:3210 and s3.<domain> -> 127.0.0.1:9000,
# then set COMPOSE_PROFILES=tunnel and paste the tunnel token below.
COMPOSE_PROFILES=
CF_TUNNEL_TOKEN=
CLOUDFLARED_VERSION=latest

# LobeHub runtime
LOBEHUB_VERSION=latest
# Local test phase: keep APP_URL on 127.0.0.1. Public domain (Cloudflare Tunnel):
# set APP_URL to your app domain, e.g. APP_URL=https://chat.example.com
# INTERNAL_APP_URL stays on 127.0.0.1 (server-side self-calls remain local).
APP_URL=http://127.0.0.1:3210
INTERNAL_APP_URL=http://127.0.0.1:3210
KEY_VAULTS_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_32
AUTH_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_32
# Registration allowlist: comma-separated emails or domains. Empty = anyone can
# register. On a public domain, set this to your approved users/domains.
AUTH_ALLOWED_EMAILS=
# Set to 1 to disable email/password and force SSO-only login.
AUTH_DISABLE_EMAIL_PASSWORD=
# Optional LobeHub feature toggles. This hides the first-run "add a few agents"
# onboarding screen while keeping the community market available.
FEATURE_FLAGS=-welcome_suggest

# PostgreSQL / PGVector
PARADEDB_VERSION=latest-pg17
LOBE_DB_NAME=lobechat
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# Redis
REDIS_VERSION=7-alpine
REDIS_PREFIX=lobechat

# RustFS S3-compatible object storage
RUSTFS_VERSION=latest
RUSTFS_ACCESS_KEY=CHANGE_ME_RUSTFS_ACCESS_KEY
RUSTFS_SECRET_KEY=CHANGE_ME_RUSTFS_SECRET_KEY
RUSTFS_LOBE_BUCKET=lobe
# CORS origin allowed to upload directly to the S3 API. Must equal APP_URL's
# origin (scheme+host+port). On a public domain set it to your app origin, e.g.
#   RUSTFS_CORS_ALLOWED_ORIGINS=https://chat.example.com
RUSTFS_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3210
# S3 endpoint the browser uses for presigned upload/download (the signing host
# must match the request host). Local test: 127.0.0.1:9000. Public domain: give
# RustFS its own hostname via the tunnel and set both to it, e.g.
#   S3_ENDPOINT=https://s3.example.com
#   S3_PUBLIC_DOMAIN=https://s3.example.com
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_DOMAIN=
S3_ENABLE_PATH_STYLE=1
S3_SET_ACL=0

# SearXNG for online search
SEARXNG_VERSION=latest
SEARXNG_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# Model provider keys (server-side shared pool). All logged-in users can use
# these; a user may also add their own private key in Settings (then theirs is
# used, otherwise the shared pool). Pool multiple keys by comma-separating them,
# e.g. DEEPSEEK_API_KEY=key1,key2 -- API_KEY_SELECT_MODE rotates across them.
API_KEY_SELECT_MODE=turn
# Leave unused providers empty.
OPENAI_API_KEY=
OPENAI_PROXY_URL=
OPENAI_MODEL_LIST=
ANTHROPIC_API_KEY=
ANTHROPIC_PROXY_URL=
GOOGLE_API_KEY=
GOOGLE_PROXY_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_PROXY_URL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL_LIST=
QWEN_API_KEY=
MOONSHOT_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=

# Backup
BACKUP_RETENTION_DAYS=14
BACKUP_CRON_TIME='30 3 * * *'

# Optional host-side proxy for provider egress. Leave empty unless you manage a
# separate proxy outside this LobeHub project.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.local
