# Core project settings
DEPLOY_DIR=/opt/Serve
TZ=Asia/Shanghai
SSH_PORT=29222

# Public domains
CHAT_DOMAIN=chat.example.com
API_DOMAIN=api.example.com
IMAGE_DOMAIN=image.example.com
PROXY_PANEL_DOMAIN=proxy.example.com
CADDY_ACME_EMAIL=admin@example.com

# Database
DB_USER=ai_admin
DB_PASS=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# NewAPI token used by Open WebUI global model access.
# Create this token in NewAPI after channels/models are configured.
# It must be an active NewAPI token with access to the model groups ordinary users should use.
# Use the OpenAI-compatible form: sk-xxxxxxxx
NEWAPI_MASTER_KEY=CHANGE_ME_OPENWEBUI_NEWAPI_TOKEN_SK_PREFIXED

# Cloudflare Tunnel token, paste only the full eyJ... token value
CF_TUNNEL_TOKEN=CHANGE_ME_CLOUDFLARE_TUNNEL_TOKEN

# Open WebUI access policy
OPENWEBUI_ENABLE_SIGNUP=true
OPENWEBUI_DEFAULT_USER_ROLE=pending
OPENWEBUI_ENABLE_DIRECT_CONNECTIONS=false
OPENWEBUI_ENABLE_API_KEYS=false
OPENWEBUI_USER_PERMISSIONS_FEATURES_API_KEYS=false
OPENWEBUI_BYPASS_MODEL_ACCESS_CONTROL=true
WEBUI_SECRET_KEY=CHANGE_ME_OPENSSL_RAND_HEX_32

# Open WebUI web search. DuckDuckGo is the simplest no-key option.
OPENWEBUI_ENABLE_WEB_SEARCH=true
OPENWEBUI_WEB_SEARCH_ENGINE=duckduckgo
OPENWEBUI_WEB_SEARCH_RESULT_COUNT=3
OPENWEBUI_WEB_SEARCH_CONCURRENT_REQUESTS=1
OPENWEBUI_WEB_LOADER_CONCURRENT_REQUESTS=3
OPENWEBUI_BYPASS_WEB_SEARCH_WEB_LOADER=true
OPENWEBUI_BYPASS_WEB_SEARCH_EMBEDDING_AND_RETRIEVAL=true
OPENWEBUI_USER_PERMISSIONS_FEATURES_WEB_SEARCH=true

# Optional initial admin notes; scripts do not print these values
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
WEBUI_ADMIN_NAME=Admin

# Image versions
POSTGRES_VERSION=15.8-alpine
NEWAPI_VERSION=latest
OPENWEBUI_VERSION=main
CLOUDFLARED_VERSION=latest
CADDY_VERSION=2-alpine
XUI_VERSION=v3.0.2

# GPT Image Playground and Caddy Basic Auth
# IMAGE_SHARED_API_KEY is a low-quota image-only NewAPI token. Leave empty to disable autofill.
IMAGE_SHARED_API_KEY=
IMAGE_BASIC_AUTH_USER=volans-image
IMAGE_BASIC_AUTH_HASH=CHANGE_ME_CADDY_BCRYPT_HASH

# 3xui panel and Reality inbound
ENABLE_XUI=true
XUI_DEPLOY_DIR=/opt/Serve/xui
XUI_PANEL_PORT=12053
XUI_REALITY_PORT=31444
XUI_ADMIN_USERNAME=xui-admin
XUI_ADMIN_PASSWORD=CHANGE_ME_XUI_ADMIN_PASSWORD

# NAT VPS egress proxy
ENABLE_NAT_PROXY=true
NAT_SSH_HOST=CHANGE_ME_NAT_SSH_HOST
NAT_SSH_PORT=CHANGE_ME_NAT_SSH_PORT
NAT_SSH_USER=CHANGE_ME_NAT_SSH_USER
NAT_SSH_KEY_PATH=/root/.ssh/nat_ed25519
NAT_SOCKS_LISTEN=127.0.0.1:10808
PRIVOXY_AI_LISTEN=172.18.0.1:7890
PRIVOXY_XUI_LISTEN=172.19.0.1:7890

# Backup
BACKUP_RETENTION_DAYS=14
BACKUP_CRON_TIME=30 3 * * *

